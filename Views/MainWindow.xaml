<Window x:Class="AlgorithmPerformanceEvaluator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Algorithm Performance Evaluator" Height="750" Width="1200"
        Background="#121212" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="15" Margin="10">
            <StackPanel Margin="15">

                <!-- TITLE -->
                <TextBlock Text="C# CODE EDITOR" Foreground="#deff9a" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                <!-- CODE EDITOR -->
                <TextBox x:Name="txtCodeEditor" 
                         Height="400" 
                         Background="Transparent" 
                         Foreground="#D4D4D4" 
                         BorderThickness="0" 
                         AcceptsReturn="True" 
                         FontFamily="Consolas" 
                         FontSize="14"
                         VerticalScrollBarVisibility="Auto"
                         Padding="10">
                    <TextBox.Text>
                        public void my_algorithm(int[] arr) 
                        {
                        Array.Sort(arr);
                        }
                    </TextBox.Text>
                </TextBox>

                <!-- ARRAY INPUT -->
                <StackPanel x:Name="manualInputPanel" Visibility="Collapsed">
                    <TextBlock Text="Array Input" Foreground="#aaa" Margin="0,10,0,5"/>

                    <TextBox x:Name="txtArrayInput"
             Height="40"
             Background="#2A2A2A"
             Foreground="White"
             BorderThickness="0"
             Padding="10"
             Text="1,2,3,4,5"/>
                </StackPanel>

                <!-- MODE BUTTONS -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                    <Button x:Name="btnManual" Content="Manual" Width="100" Margin="5"
        Background="#2A2A2A" Foreground="White"
        Click="btnManual_Click"/>

                    <Button x:Name="btnAuto" Content="Auto" Width="100" Margin="5"
        Background="#2A2A2A" Foreground="White"
        Click="btnAuto_Click"/>
                </StackPanel>

                <!-- RUN BUTTON -->
                <Button x:Name="btnRun" 
                        Content="Run Analysis" 
                        Height="45" 
                        Margin="0,10,0,0" 
                        Background="#deff9a" 
                        Foreground="#000" 
                        FontWeight="Bold"
                        Click="btnRun_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>

        <!-- RIGHT PANEL -->
        <StackPanel Grid.Column="1" Margin="10">

            <!-- COMPLEXITY -->
            <Border Background="#1E1E1E" CornerRadius="15" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="DETECTED COMPLEXITY" Foreground="#daffde" FontSize="14" Opacity="0.7"/>
                    <TextBlock x:Name="lblComplexity" Text="O(?)" Foreground="#deff9a" FontSize="48" FontWeight="Bold"/>

                    <!-- CONFIDENCE -->
                    <TextBlock Text="Confidence" Foreground="#aaa" Margin="0,10,0,0"/>
                    <TextBlock x:Name="lblConfidence" Foreground="#deff9a" FontSize="16"/>
                </StackPanel>
            </Border>

            <!-- CHART PLACEHOLDER -->
            <Border Background="#1E1E1E" CornerRadius="15" Height="430" Padding="10">
                <Grid>
                    <Border Background="#2A2A2A" CornerRadius="10">
                        <TextBlock Text="Chart will appear here"
                                   Foreground="#777"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

        </StackPanel>
    </Grid>
</Window>