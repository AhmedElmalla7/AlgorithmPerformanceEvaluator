<Window x:Class="AlgorithmPerformanceEvaluator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Algorithm Evaluator"
        Height="600" Width="1000"
        Background="#121212">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: CODE EDITOR -->
        <Border Background="#1E1E2F" CornerRadius="15" Padding="15" Margin="10">
            <StackPanel>

                <TextBlock Text="Write Your Algorithm (C#)"
                           Foreground="White"
                           FontSize="18"
                           Margin="0,0,0,10"/>

                <TextBox x:Name="codeBox"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas"
                         FontSize="14"
                         Background="#2A2A40"
                         Foreground="White"
                         Height="400"
                         Text="foreach(var x in arr){ }"/>

                <Button Content="Run Analysis"
                        Height="45"
                        Margin="0,15,0,0"
                        Background="#4CAF50"
                        Foreground="White"
                        FontWeight="Bold"
                        //>Click="Run_Click"/>

            </StackPanel>
        </Border>

        <!-- RIGHT -->
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>

            <!-- GRAPH -->
            <Border Background="#1E1E2F"
                    CornerRadius="15"
                    Margin="10"
                    Grid.Row="0">

                <!-- هنحط الرسم هنا -->
                <Canvas x:Name="chartCanvas"/>
            </Border>

            <!-- RESULT -->
            <Border Background="#1E1E2F"
                    CornerRadius="15"
                    Margin="10"
                    Grid.Row="1"
                    Padding="20">

                <StackPanel>
                    <TextBlock Text="Estimated Complexity"
                               Foreground="Gray"
                               FontSize="14"/>

                    <TextBlock x:Name="resultText"
                               Text="Waiting..."
                               Foreground="#4CAF50"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,10,0,0"/>
                </StackPanel>

            </Border>

        </Grid>

    </Grid>
</Window>